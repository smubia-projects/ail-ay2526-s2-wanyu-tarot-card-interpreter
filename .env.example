# AI API key and model (defaults to OpenRouter but can be any OpenAI-compatible proxy)
API_KEY=sk-or-...
MODEL_NAME=openai/gpt-4.1-mini
API_BASE_URL=https://openrouter.ai/api/v1
# CORS — comma-separated frontend origins (set to Vercel URL after deploy)
CORS_ORIGINS=http://localhost:5173

# Upstash Redis — rate limiting (optional for local dev). Shared engine: limits
# come from the central control sheet at runtime, with the values below as
# fallbacks. See DOCS/shared/rate-limit/central-config.md
# Use the names from the Upstash dashboard (REST_); the short names also work.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Rate limit tuning (optional, fallback defaults shown)
# RATE_LIMIT_READING_MAX=5          # max readings per IP per window
# RATE_LIMIT_WINDOW_SECONDS=432000  # 5 days
